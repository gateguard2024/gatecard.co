# Supabase — same project as portal.gateguard.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio — masked calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # The masked caller ID residents see
TWILIO_TWIML_APP_SID=      # Optional: for browser-based calling later

# Eagle Eye Networks — snapshot on visitor call
EEN_API_KEY=
EEN_BASE_URL=https://api.eagleeyenetworks.com

# GateGuard Portal — internal API for gate open (Brivo proxy)
GATEGUARD_PORTAL_URL=https://portal.gateguard.co
GATEGUARD_API_SECRET=      # Shared secret for internal API calls

# KORE Wireless (Super SIM — formerly Twilio IoT, acquired June 2023)
# Docs: https://supersim.api.korewireless.com/v1
# Auth: OAuth 2.0 client credentials → https://api.korewireless.com/api-services/v1/auth/token
KORE_CLIENT_ID=
KORE_CLIENT_SECRET=
KORE_FLEET_SID=            # HF... — the fleet SIMs are assigned to on activation
# Device APN: "super" | Username: blank | Password: blank | Data Roaming: ON

# App
NEXT_PUBLIC_APP_URL=https://gatecard.co
CRON_SECRET=               # Protects /api/cron/* routes
