# ─── GateCard Pi Sync Agent — Environment Variables ──────────────────────────
# Copy this file to /etc/gatecard-agent.env on the Pi (see setup.sh).
# DO NOT commit the real .env file — it contains secrets.

# ── Supabase (cloud) ──────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Site (optional) ───────────────────────────────────────────────────────────
# Lock this Pi to a specific property slug. If blank, syncs all configured sites.
# Recommended: set this so one Pi = one property.
SITE_SLUG=your-property-slug

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to "debug" for verbose output during setup/troubleshooting.
# Remove or set to "" in production.
LOG_LEVEL=
